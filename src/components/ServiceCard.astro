---
interface Props {
  titleEn: string;
  titleIt: string;
  textEn: string;
  textIt: string;
  index: number;
}

const { titleEn, titleIt, textEn, textIt, index } = Astro.props;
---

<article class="service-card reveal-card" style={`--card-index: ${index}`}>
  <div class="service-number">{String(index + 1).padStart(2, "0")}</div>
  <h3>
    <span data-lang-content="en">{titleEn}</span>
    <span data-lang-content="it">{titleIt}</span>
  </h3>
  <p>
    <span data-lang-content="en">{textEn}</span>
    <span data-lang-content="it">{textIt}</span>
  </p>
</article>
