---
import { siteContent } from "../content/siteContent";
---

<section class="section about-section" id="about" aria-labelledby="about-title">
  <div class="section-wrap split-layout">
    <div>
      <p class="eyebrow accent-line">
        <span data-lang-content="en">{siteContent.en.about.eyebrow}</span>
        <span data-lang-content="it">{siteContent.it.about.eyebrow}</span>
      </p>
      <h2 id="about-title">
        <span data-lang-content="en">{siteContent.en.about.title}</span>
        <span data-lang-content="it">{siteContent.it.about.title}</span>
      </h2>
    </div>
    <div class="rich-copy">
      {siteContent.en.about.body.map((paragraph, index) => (
        <p>
          <span data-lang-content="en">{paragraph}</span>
          <span data-lang-content="it">{siteContent.it.about.body[index]}</span>
        </p>
      ))}
      <div class="stat-grid">
        {siteContent.en.about.stats.map(([value, label], index) => (
          <div class="stat">
            <strong>
              <span data-lang-content="en">{value}</span>
              <span data-lang-content="it">{siteContent.it.about.stats[index][0]}</span>
            </strong>
            <span>
              <span data-lang-content="en">{label}</span>
              <span data-lang-content="it">{siteContent.it.about.stats[index][1]}</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
