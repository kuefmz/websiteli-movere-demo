---
import { siteContent } from "../content/siteContent";
---

<section class="section suitable-section" id="suitable" aria-labelledby="suitable-title">
  <div class="section-wrap split-layout">
    <div>
      <p class="eyebrow accent-line">
        <span data-lang-content="en">{siteContent.en.suitable.eyebrow}</span>
        <span data-lang-content="it">{siteContent.it.suitable.eyebrow}</span>
      </p>
      <h2 id="suitable-title">
        <span data-lang-content="en">{siteContent.en.suitable.title}</span>
        <span data-lang-content="it">{siteContent.it.suitable.title}</span>
      </h2>
      <p class="section-lead">
        <span data-lang-content="en">{siteContent.en.suitable.intro}</span>
        <span data-lang-content="it">{siteContent.it.suitable.intro}</span>
      </p>
    </div>
    <ul class="suitable-list">
      {siteContent.en.suitable.items.map((item, index) => (
        <li>
          <span aria-hidden="true"></span>
          <p>
            <span data-lang-content="en">{item}</span>
            <span data-lang-content="it">{siteContent.it.suitable.items[index]}</span>
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
