---
import { BRAND } from "../config/brand";
import { siteContent } from "../content/siteContent";
import LanguageSwitcher from "./LanguageSwitcher";
import Logo from "./Logo.astro";

const whatsappUrl = `https://wa.me/${BRAND.contact.whatsappNumber}`;
---

<footer class="site-footer">
  <div class="section-wrap footer-shell">
    <div class="footer-brand">
      <Logo variant="light" size="small" />
      <p>
        <span data-lang-content="en">{BRAND.location.en}</span>
        <span data-lang-content="it">{BRAND.location.it}</span>
      </p>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="#about">
        <span data-lang-content="en">{siteContent.en.nav.about}</span>
        <span data-lang-content="it">{siteContent.it.nav.about}</span>
      </a>
      <a href="#treatments">
        <span data-lang-content="en">{siteContent.en.nav.treatments}</span>
        <span data-lang-content="it">{siteContent.it.nav.treatments}</span>
      </a>
      <a href="#method">
        <span data-lang-content="en">{siteContent.en.nav.method}</span>
        <span data-lang-content="it">{siteContent.it.nav.method}</span>
      </a>
      <a href="#contact">
        <span data-lang-content="en">{siteContent.en.nav.contact}</span>
        <span data-lang-content="it">{siteContent.it.nav.contact}</span>
      </a>
    </nav>
    <div class="footer-action">
      <LanguageSwitcher client:load />
      <a class="button button-small" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
        <span data-lang-content="en">{BRAND.cta.en}</span>
        <span data-lang-content="it">{BRAND.cta.it}</span>
      </a>
    </div>
    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} {BRAND.name}</p>
      <p>
        <span data-lang-content="en">{siteContent.en.footer.builtBy}</span>
        <span data-lang-content="it">{siteContent.it.footer.builtBy}</span>
        <a href={BRAND.websiteliUrl} target="_blank" rel="noopener noreferrer">Websiteli.ch</a>
      </p>
    </div>
  </div>
</footer>
