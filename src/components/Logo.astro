---
import { BRAND } from "../config/brand";
import { withBase } from "../utils/paths";

interface Props {
  variant?: "light" | "dark";
  size?: "small" | "default" | "large";
}

const { variant = "dark", size = "default" } = Astro.props;
---

<a class:list={["logo", `logo-${variant}`, `logo-${size}`]} href="#top" aria-label={`${BRAND.name} home`}>
  <span class="logo-raster" aria-hidden="true">
    <img src={withBase(BRAND.logo)} alt="" loading="eager" decoding="async" />
  </span>
</a>

<style>
  .logo {
    flex: 0 0 auto;
    border-radius: 999px;
    transition: transform 220ms var(--ease-out), filter 220ms var(--ease-out);
  }

  .logo:hover {
    transform: translateY(-1px);
  }

  .logo:focus-visible {
    outline-offset: 0.35rem;
  }

  .logo-raster {
    filter: drop-shadow(0 8px 18px rgb(17 17 17 / 0.08));
  }

  @media (max-width: 760px) {
    .logo-raster {
      width: clamp(168px, 48vw, 190px);
      height: 76px;
    }
  }

  @media (max-width: 460px) {
    .logo-raster {
      width: min(184px, 54vw);
      height: 78px;
    }
  }
</style>